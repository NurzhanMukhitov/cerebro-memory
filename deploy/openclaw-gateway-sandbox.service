[Unit]
Description=OpenClaw Gateway (sandbox)
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/cerebro/.openclaw/workspace-sandbox
EnvironmentFile=/home/cerebro/.openclaw/sandbox.env
ExecStart=/usr/bin/env openclaw gateway start
Restart=on-failure
RestartSec=10

[Install]
WantedBy=default.target
